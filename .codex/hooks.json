{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp.*|Read|read|read_file|read_many_files|grep|glob",
        "hooks": [
          {
            "type": "command",
            "command": "core/bin/hook env_guard --agent codex",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "core/bin/hook session_start --agent codex",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "core/bin/hook user_prompt --agent codex",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "core/bin/hook agent_stop --agent codex",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
