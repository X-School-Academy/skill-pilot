#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

if [[ "$#" -lt 1 ]]; then
  echo "Usage: core/bin/uv-install <package> [package...]"
  exit 1
fi

cd "$REPO_ROOT"
exec uv --directory core/engine add "$@"
