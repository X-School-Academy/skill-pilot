#!/usr/bin/env bash
# Usage:
#   core/bin/local-openai-infer --type text --prompt "hello"
#   core/bin/local-openai-infer --type text --prompt "hello" --model llama3.2
#   core/bin/local-openai-infer --type image --prompt "describe this image" --file_path /path/to/image.png
#   core/bin/local-openai-infer --type image --prompt "describe this image" --file_path /path/to/image.png --model llava
#
# Environment:
#   LOCAL_OPENAI_BASE_URL   OpenAI-compatible base URL or full /v1/chat/completions URL
#   LOCAL_OPENAI_INFER_MODEL Optional default model
#   LOCAL_OPENAI_INFER_API_KEY Optional API key, defaults to local-openai

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

cd "$REPO_ROOT"
exec uv --directory core/engine run python tools/local_openai_infer.py "$@"
