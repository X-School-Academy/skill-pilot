#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
CALLER_DIR="$(pwd)"

# Resolve relative paths to absolute before cd to repo root
resolve() {
  local p="$1"
  if [[ "$p" != /* && "$p" != *://* ]]; then
    echo "${CALLER_DIR}/${p}"
  else
    echo "$p"
  fi
}

args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o)
      args+=("$1")
      shift
      [[ $# -gt 0 ]] && args+=("$(resolve "$1")")
      ;;
    -*)
      args+=("$1")
      ;;
    *)
      args+=("$(resolve "$1")")
      ;;
  esac
  shift
done

cd "$REPO_ROOT"
exec uv --directory core/engine run markitdown "${args[@]}"
