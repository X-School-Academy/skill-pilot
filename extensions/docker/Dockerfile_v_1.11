FROM skillpilotai/media-mcp:v_1.10

ENV DEBIAN_FRONTEND=noninteractive

# --- Scripts ---
COPY --chown=ubuntu:ubuntu download_models.sh /home/ubuntu/workspace/download_models.sh
COPY --chown=ubuntu:ubuntu entrypoint.sh /home/ubuntu/workspace/entrypoint.sh
RUN chmod +x /home/ubuntu/workspace/download_models.sh /home/ubuntu/workspace/entrypoint.sh

# ---
WORKDIR /home/ubuntu/workspace

EXPOSE 22 8080 7860 8188 3478 3478/udp 5349 5349/udp

RUN sudo apt-get update && sudo apt-get install -y coturn

# Welcome message shown via MOTD on login and for interactive non-login bash shells
RUN sudo sh -c 'printf "%s\n" \
    "" \
    "  ╔══════════════════════════════════════════════════════════════╗" \
    "  ║         ✦  Skill Pilot Media Server  ✦                      ║" \
    "  ╠══════════════════════════════════════════════════════════════╣" \
    "  ║                                                              ║" \
    "  ║  Ready to create with AI-powered tools:                     ║" \
    "  ║                                                              ║" \
    "  ║    ComfyUI    ·  AI image & video generation                ║" \
    "  ║    IndexTTS   ·  High-quality text-to-speech                ║" \
    "  ║    MuseTalk   ·  Real-time talking face synthesis           ║" \
    "  ║    SongBloom  ·  AI music & song creation                   ║" \
    "  ║                                                              ║" \
    "  ╠══════════════════════════════════════════════════════════════╣" \
    "  ║  Free & Open Source  ·  MIT License                         ║" \
    "  ║                                                              ║" \
    "  ║  Need help? Join our Discord community!                     ║" \
    "  ║  Find the invite link at:  https://skill-pilot.ai           ║" \
    "  ╚══════════════════════════════════════════════════════════════╝" \
    "" \
    > /etc/motd && \
    printf "\n# Show MOTD for interactive non-login bash shells started via docker exec.\nif [ -r /etc/motd ] && ! shopt -q login_shell; then\n    cat /etc/motd\nfi\n" >> /etc/bash.bashrc'

ENTRYPOINT ["/home/ubuntu/workspace/entrypoint.sh"]
